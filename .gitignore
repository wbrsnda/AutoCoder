*.db                    # SQLite / ChromaDB 数据库文件
chroma_db/              # ChromaDB 持久化目录
*.sqlite
*.sqlite3
checkpoints/            # MemorySaver checkpoint
memory/                 # LangGraph 持久化
output/                 # 运行产出

