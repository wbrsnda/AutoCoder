{
  "name": "skill-dev",
  "description": "Skill for software development workflow",
  "rules": [
    {
      "event": "PostToolUse",
      "matcher": "mcp_execute_bash",
      "condition": {
        "command": {
          "pattern": "^git\\s+commit",
          "operator": "regex"
        }
      },
      "action": "auto-approve",
      "message": "Commit auto-approved."
    }
  ]
}